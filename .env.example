APP_NAME="Mini-TES Front"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX
APP_TIMEZONE=America/Mexico_City

# ─── Base de datos (SQLite por defecto, sin configuración extra) ───────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mini_tes
# DB_USERNAME=root
# DB_PASSWORD=

# ─── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ─── Logs ──────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── OpenAI (requerido para el asistente de voz "Atenea") ─────────────────────
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TOKEN_TTL_SECONDS=600

# ─── Mini-TES Backend (GraphQL) ────────────────────────────────────────────────
MINI_TES_GRAPHQL_URL=http://127.0.0.1:4000/graphql

# ─── Mail (no requerido para correr la app) ────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@mini-tes.local"
MAIL_FROM_NAME="${APP_NAME}"
